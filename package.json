{
  "name": "@uor-foundation/primeos",
  "version": "1.1.0",
  "description": "A neural network-based operating system built on the Prime Framework with mathematical coherence principles",
  "main": "dist/primeos.js",
  "module": "dist/primeos.esm.js",
  "browser": "dist/primeos.min.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js \"tests/(?!extreme-conditions|integration-tests|uor-verification-tests).+\\.js$\"",
    "test:extreme": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js tests/extreme-conditions-tests.js",
    "test:extreme:batched": "node --expose-gc scripts/run/run-extreme-tests.js",
    "test:extreme:basic": "node --expose-gc scripts/run/run-extreme-tests.js basic",
    "test:extreme:rna": "node --expose-gc scripts/run/run-extreme-tests.js rna-folding",
    "test:extreme:fiber": "node --expose-gc scripts/run/run-extreme-tests.js high-dimension",
    "test:extreme:gradient": "node --expose-gc scripts/run/run-extreme-tests.js coherence-gradient",
    "test:extreme:numerical": "node --expose-gc scripts/run/run-extreme-tests.js numerical-propagation",
    "benchmark:extreme": "node scripts/benchmarks/run-extreme-benchmarks.js",
    "benchmark:extreme:verbose": "node scripts/benchmarks/run-extreme-benchmarks.js --verbose",
    "benchmark:extreme:json": "node scripts/benchmarks/run-extreme-benchmarks.js --json",
    "benchmark:extreme:custom": "node scripts/benchmarks/run-extreme-benchmarks.js --custom --verbose",
    "debug:distributed": "node scripts/debug/debug-distributed.js",
    "debug:matrix": "node scripts/debug/debug-matrix.js",
    "debug:model": "node scripts/debug/debug-model.js",
    "test:uor": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js tests/uor-verification-tests.js --testPathIgnorePatterns=\"\"",
    "test:integration": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js tests/integration-tests.js --testPathIgnorePatterns=\"\"",
    "test:browser": "node scripts/run/run-browser-tests.js",
    "test:neural": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js tests/neural-tests.js --testPathIgnorePatterns=\"\"",
    "test:distributed": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js tests/distributed-tests.js --testPathIgnorePatterns=\"\"",
    "test:core": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js tests/coherence-tests.js",
    "test:stable": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js \"tests/(coherence|framework|mathematics|prime-math|manifold-operations)-tests.js\"",
    "test:coherence": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js tests/distributed-coherence-integration-tests.js --testPathIgnorePatterns=\"\"",
    "test:coherence:bench": "node tests/distributed-coherence-benchmarks.js",
    "test:coherence:mock": "node tests/distributed-coherence-mock-network.js",
    "test:consciousness": "node scripts/run/run-consciousness-tests.js",
    "test:verify": "node scripts/run/run-verification-tests.js",
    "test:verify:verbose": "node scripts/run/run-verification-tests.js --verbose",
    "test:verify:json": "node scripts/run/run-verification-tests.js --json",
    "test:ci": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js --testTimeout=90000 \"tests/(?!extreme-conditions|integration-tests|uor-verification-tests).+\\.js$\"",
    "test:all": "npm test && npm run test:integration && npm run test:neural && npm run test:distributed && npm run test:coherence && npm run test:consciousness && npm run test:verify && npm run test:browser",
    "build": "rollup -c build/rollup.config.js",
    "build:dev": "rollup -c build/rollup.config.js --environment BUILD:development",
    "build:prod": "rollup -c build/rollup.config.js --environment BUILD:production",
    "lint": "eslint \"src/**/*.js\" \"scripts/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"scripts/**/*.js\"",
    "docs": "jsdoc -c jsdoc.config.json -d docs/api",
    "docs:dev": "jsdoc -c jsdoc.config.json -d docs/api -w",
    "pages:build": "cd docs && bundle exec jekyll build",
    "pages:serve": "cd docs && bundle exec jekyll serve",
    "pages:deploy": "gh-pages -d docs/_site",
    "clean": "rm -rf dist coverage docs/api",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test:ci && npm run lint"
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "docs/guides",
    "docs/specs",
    "LICENSE",
    "README.md",
    "CONTRIBUTING-COHERENCE.md",
    "KNOWN-ISSUES.md"
  ],
  "keywords": [
    "primeos",
    "prime-framework",
    "coherence",
    "neural-network",
    "clifford-algebra",
    "mathematics",
    "geometry",
    "lie-groups",
    "components",
    "universal-object-reference"
  ],
  "author": "PrimeOS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UOR-Foundation/PrimeOS.git"
  },
  "bugs": {
    "url": "https://github.com/UOR-Foundation/PrimeOS/issues"
  },
  "homepage": "https://uor.foundation/PrimeOS",
  "devDependencies": {
    "@babel/core": "^7.22.9",
    "@babel/preset-env": "^7.22.9",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^25.0.3",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@rollup/plugin-terser": "^0.4.3",
    "babel-jest": "^29.6.1",
    "docdash": "^2.0.2",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "gh-pages": "^6.1.1",
    "jest": "^29.6.1",
    "jest-environment-jsdom": "^29.6.1",
    "jsdoc": "^4.0.2",
    "prettier": "^3.0.0",
    "puppeteer": "^24.4.0",
    "rollup": "^3.26.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {}
}
