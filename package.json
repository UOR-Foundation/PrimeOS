{
  "name": "@uor-foundation/primeos",
  "version": "1.1.1",
  "description": "A neural network-based operating system built on the Prime Framework with mathematical coherence principles",
  "main": "dist/primeos.js",
  "module": "dist/primeos.esm.js",
  "browser": "dist/primeos.min.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node tests/runners/run-all.js",
    "test:unit": "node --max-old-space-size=8192 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/**/*.test.js\"",
    "test:unit:core": "node --max-old-space-size=4096 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/core/**/*.test.js\"",
    "test:unit:math": "node --max-old-space-size=4096 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/math/**/*.test.js\"",
    "test:unit:components": "node --max-old-space-size=4096 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/components/**/*.test.js\"",
    "test:unit:coherence": "node --max-old-space-size=4096 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/coherence/**/*.test.js\"",
    "test:unit:storage": "node --max-old-space-size=4096 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/storage/**/*.test.js\"",
    "test:unit:neural": "node --max-old-space-size=4096 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/neural/**/*.test.js\"",
    "test:unit:distributed": "node --max-old-space-size=4096 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/distributed/**/*.test.js\"",
    "test:unit:veneer": "node --max-old-space-size=4096 ./node_modules/.bin/jest --config build/jest.config.js \"tests/unit/veneer/**/*.test.js\"",
    "test:integration": "node --max-old-space-size=6144 ./node_modules/.bin/jest --config build/jest.config.js \"tests/integration/**/*.test.js\"",
    "test:integration:coherence": "node --max-old-space-size=6144 ./node_modules/.bin/jest --config build/jest.config.js \"tests/integration/coherence/**/*.test.js\"",
    "test:integration:distributed": "node --max-old-space-size=6144 ./node_modules/.bin/jest --config build/jest.config.js \"tests/integration/distributed/**/*.test.js\"",
    "test:integration:storage": "node --max-old-space-size=6144 ./node_modules/.bin/jest --config build/jest.config.js \"tests/integration/storage/**/*.test.js\"",
    "test:integration:consciousness": "node --max-old-space-size=6144 ./node_modules/.bin/jest --config build/jest.config.js \"tests/integration/consciousness/**/*.test.js\"",
    "test:integration:framework": "node --max-old-space-size=6144 ./node_modules/.bin/jest --config build/jest.config.js \"tests/integration/framework/**/*.test.js\"",
    "test:integration:veneer": "node --max-old-space-size=6144 ./node_modules/.bin/jest --config build/jest.config.js \"tests/integration/veneer/**/*.test.js\"",
    "test:extreme": "node --expose-gc tests/runners/run-extreme.js",
    "test:extreme:math": "node --expose-gc tests/runners/run-extreme.js matrix-extreme",
    "test:extreme:svd": "node --expose-gc tests/runners/run-extreme.js svd-extreme",
    "test:extreme:numerical": "node --expose-gc tests/runners/run-extreme.js numerical-stability",
    "test:extreme:neural": "node --expose-gc tests/runners/run-extreme.js neural-extreme",
    "test:extreme:distributed": "node --expose-gc tests/runners/run-extreme.js distributed-extreme",
    "test:extreme:consciousness": "node --expose-gc tests/runners/run-extreme.js consciousness-extreme",
    "test:performance": "node --max-old-space-size=6144 ./node_modules/.bin/jest --config build/jest.config.js \"tests/performance/**/*.test.js\"",
    "test:browser": "node scripts/run/run-browser-tests.js",
    "test:ci": "node tests/runners/run-all.js",
    "test:all": "node tests/runners/run-all.js",
    "cleanup:tests": "node scripts/cleanup-old-tests.js",
    
    "benchmark:extreme": "node scripts/benchmarks/run-extreme-benchmarks.js",
    "benchmark:extreme:verbose": "node scripts/benchmarks/run-extreme-benchmarks.js --verbose",
    "benchmark:extreme:json": "node scripts/benchmarks/run-extreme-benchmarks.js --json",
    "benchmark:extreme:custom": "node scripts/benchmarks/run-extreme-benchmarks.js --custom --verbose",
    "debug:distributed": "node scripts/debug/debug-distributed.js",
    "debug:matrix": "node scripts/debug/debug-matrix.js",
    "debug:model": "node scripts/debug/debug-model.js",
    "build": "rollup -c build/rollup.config.js",
    "build:dev": "rollup -c build/rollup.config.js --environment BUILD:development",
    "build:prod": "rollup -c build/rollup.config.js --environment BUILD:production",
    "lint": "eslint \"src/**/*.js\" \"scripts/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"scripts/**/*.js\"",
    "docs": "jsdoc -c jsdoc.config.json -d docs/api",
    "docs:dev": "jsdoc -c jsdoc.config.json -d docs/api -w",
    "pages:build": "cd docs && bundle exec jekyll build",
    "pages:serve": "cd docs && bundle exec jekyll serve",
    "pages:deploy": "gh-pages -d docs/_site",
    "clean": "rm -rf dist coverage docs/api",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test:ci && npm run lint"
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "docs/guides",
    "docs/specs",
    "LICENSE",
    "README.md",
    "CONTRIBUTING-COHERENCE.md",
    "KNOWN-ISSUES.md"
  ],
  "keywords": [
    "primeos",
    "prime-framework",
    "coherence",
    "neural-network",
    "clifford-algebra",
    "mathematics",
    "geometry",
    "lie-groups",
    "components",
    "universal-object-reference"
  ],
  "author": "PrimeOS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UOR-Foundation/PrimeOS.git"
  },
  "bugs": {
    "url": "https://github.com/UOR-Foundation/PrimeOS/issues"
  },
  "homepage": "https://uor.foundation/PrimeOS",
  "devDependencies": {
    "@babel/core": "^7.22.9",
    "@babel/preset-env": "^7.22.9",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^25.0.3",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@rollup/plugin-terser": "^0.4.3",
    "babel-jest": "^29.6.1",
    "docdash": "^2.0.2",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "gh-pages": "^6.1.1",
    "jest": "^29.6.1",
    "jest-environment-jsdom": "^29.6.1",
    "jsdoc": "^4.0.2",
    "prettier": "^3.0.0",
    "puppeteer": "^24.4.0",
    "rollup": "^3.26.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "semver": "^7.7.1",
    "yargs": "^17.7.2"
  }
}
