{
  "name": "primeos-reference-implementation",
  "version": "1.0.0",
  "description": "Reference implementation for the PrimeOS operating system",
  "main": "js/app.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "node tests/shell-integration-tests.js",
    "test:shell": "node tests/shell-integration-tests.js",
    "test:browser": "node run-browser-tests.js",
    "test:secure-vault": "node run-secure-vault-browser-tests.js",
    "test:all": "npm run test && npm run test:integration && npm run test:browser",
    "build": "rollup -c",
    "start": "serve .",
    "lint": "eslint ."
  },
  "keywords": [
    "primeos",
    "os",
    "reference",
    "implementation",
    "mathematical",
    "coherence"
  ],
  "author": "PrimeOS Team",
  "license": "MIT",
  "dependencies": {
    "idb": "^7.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^25.0.2",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@rollup/plugin-terser": "^0.4.3",
    "eslint": "^8.43.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "puppeteer": "^24.4.0",
    "rollup": "^3.25.1",
    "serve": "^14.2.0",
    "serve-handler": "^6.1.6"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleFileExtensions": [
      "js"
    ],
    "moduleDirectories": [
      "node_modules"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.js"
    ],
    "collectCoverageFrom": [
      "core/**/*.js",
      "js/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ]
  }
}
