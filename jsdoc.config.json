{
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc", "closure"]
  },
  "source": {
    "include": ["src", "README.md"],
    "includePattern": "\\.js$",
    "excludePattern": "(node_modules/|docs/|dist/)"
  },
  "plugins": [
    "plugins/markdown"
  ],
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true,
    "useLongnameInNav": false,
    "showInheritedInNav": true
  },
  "opts": {
    "destination": "./docs/api",
    "encoding": "utf8",
    "private": true,
    "recurse": true,
    "template": "./node_modules/docdash"
  },
  "markdown": {
    "parser": "gfm",
    "hardwrap": true
  },
  "docdash": {
    "static": true,
    "sort": true,
    "sectionOrder": [
      "Classes",
      "Modules",
      "Externals",
      "Events",
      "Namespaces",
      "Mixins",
      "Tutorials",
      "Interfaces"
    ],
    "meta": {
      "title": "PrimeOS API Documentation",
      "description": "API documentation for the PrimeOS JavaScript library",
      "keyword": "primeos, api, documentation, javascript"
    },
    "search": true,
    "collapse": true,
    "wrap": true,
    "typedefs": true,
    "navLevel": 4,
    "private": true,
    "removeQuotes": "none",
    "scripts": [],
    "menu": {
      "GitHub Repository": {
        "href": "https://github.com/UOR-Foundation/PrimeOS",
        "target": "_blank",
        "class": "menu-item",
        "id": "repository"
      },
      "PrimeOS Website": {
        "href": "https://uor-foundation.github.io/PrimeOS/",
        "target": "_blank",
        "class": "menu-item",
        "id": "website"
      }
    }
  }
}